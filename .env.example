# SPC Insights — Statistical Process Control Platform
# Environment Configuration Template
# Copy this file to .env and fill in the values below.

# Application Environment (e.g., development, testing, production)
# In production, set this to 'production' to disable debug mode.
FLASK_ENV=development

# Secret Key for Flask sessions and CSRF protection
# Replace with a strong random secret before production deployment.
SECRET_KEY=dev-secret-change-me

# Database Configuration
# By default, falls back to a local SQLite database inside the `instance/` folder if not set.
# For future PostgreSQL migration, uncomment and set the URL like below:
# DATABASE_URL=postgresql://user:password@localhost/spc_db
